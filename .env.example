# =============================================================
# Luck Miner — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The FRONTEND (artifacts/luck-miner) needs no environment
# variables — it runs fully in the browser using localStorage.
#
# The BACKEND (artifacts/api-server) requires the values below.
# =============================================================

# ------------------------------------------------------------
# BACKEND — Express API Server
# ------------------------------------------------------------

# Port the Express server listens on
PORT=8080

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local development: install Postgres and create a DB named luck_miner
DATABASE_URL=postgresql://postgres:password@localhost:5432/luck_miner

# ------------------------------------------------------------
# TELEGRAM MINI APP INTEGRATION (not needed for local prototype)
# ------------------------------------------------------------

# Your Telegram bot token from @BotFather
# Used to verify Telegram initData HMAC signatures on the backend
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# ------------------------------------------------------------
# OPTIONAL — NODE ENVIRONMENT
# ------------------------------------------------------------

# Set to "production" when deploying
NODE_ENV=development
